  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.6",
    "bn.js": "^5.2.1"
  }
}
