{
  "name": "@dnipro/sdk",
  "version": "0.1.0",
  "description": "Dnipro Universal Yield Adapter Standard — TypeScript SDK",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
