# Dnipro Environment Variables
# Copy to .env.local for local development

# ── RPC ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_NETWORK=mainnet-beta

# For devnet development:
# NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
# NEXT_PUBLIC_NETWORK=devnet

# For local validator:
# NEXT_PUBLIC_RPC_URL=http://localhost:8899
# NEXT_PUBLIC_NETWORK=localnet

# ── Program IDs (override for devnet/localnet) ────────────────────────────────
# NEXT_PUBLIC_DISPATCHER_PROGRAM_ID=DniproDispatcher1111111111111111111111111111
# NEXT_PUBLIC_REGISTRY_PROGRAM_ID=DniproRegistry11111111111111111111111111111

# ── Feature flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MOCK_DATA=true   # Use mock data when chain unavailable
NEXT_PUBLIC_FEE_BPS=30       # Display fee to users

# ── Analytics (optional) ──────────────────────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=dnipro.finance
