{
  "name": "dnipro",
  "version": "0.1.0",
  "description": "Dnipro — Universal Yield Adapter Standard for Solana",
  "private": true,
  "workspaces": [
    "sdk",
    "cli",
    "web"
  ],
  "scripts": {
    "build":       "yarn workspace @dnipro/sdk build && yarn workspace @dnipro/cli build && yarn workspace dnipro-web build",
    "dev":         "yarn workspace dnipro-web dev",
    "build:sdk":   "yarn workspace @dnipro/sdk build",
    "build:cli":   "yarn workspace @dnipro/cli build",
    "build:web":   "yarn workspace dnipro-web build",
    "test":        "anchor test",
    "test:unit":   "yarn workspace @dnipro/sdk test",
    "lint":        "yarn workspaces run lint",
    "anchor:build": "anchor build",
    "anchor:test":  "anchor test",
    "anchor:deploy": "anchor deploy",
    "generate":    "yarn workspace @dnipro/cli start generate"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.0",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "bn.js": "^5.2.1",
    "chai": "^4.5.0",
    "mocha": "^10.7.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
